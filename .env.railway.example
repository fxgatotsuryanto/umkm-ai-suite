# ============================================================
# UMKM AI Suite — Railway Environment Variables
# Backend: aimarketingstrategic
# ============================================================
# Salin nilai-nilai ini ke Railway Dashboard:
#   Railway Project → Backend Service → Variables
# ============================================================

# ── WAJIB: AI / OpenRouter ───────────────────────────────────
# Daftar di https://openrouter.ai → API Keys
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini

# ── WAJIB: Keamanan ──────────────────────────────────────────
# Generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ganti-dengan-random-string-min-64-karakter-sangat-aman

# Admin key untuk endpoint /api/admin/* (kosongkan = pakai SECRET_KEY)
ADMIN_API_KEY=

# ── WAJIB: Token Awal ────────────────────────────────────────
# Jumlah token yang diberikan saat startup jika balance = 0
# Berguna sebelum CLOUD_API_KEY dikonfigurasi
# Hapus atau set ke 0 setelah CLOUD_API_KEY dikonfigurasi
INITIAL_TOKEN_BALANCE=500

# ── OPSIONAL: Cloud License Server ───────────────────────────
# URL cloud server untuk sinkronisasi token & lisensi
# Kosongkan jika belum ada cloud server
CLOUD_API_URL=https://your-cloud.railway.app
CLOUD_API_KEY=

# ── OPSIONAL: CORS ───────────────────────────────────────────
# URL dashboard yang diizinkan (pisahkan dengan koma)
# Kosongkan = izinkan semua origin (*)
CORS_ORIGINS=https://mindful-vibrancy-production-8f56.up.railway.app,http://localhost:3000

# ── OPSIONAL: Profil Bisnis ──────────────────────────────────
BUSINESS_NAME=AI Marketing Strategic
BUSINESS_TYPE=marketing

# ── OPSIONAL: Database ───────────────────────────────────────
# Default: SQLite (Railway Volume atau ephemeral)
# Untuk PostgreSQL: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./umkm_local.db

# ── OPSIONAL: WhatsApp / n8n ─────────────────────────────────
N8N_WEBHOOK_SECRET=

# ── OPSIONAL: Telegram Notifikasi ───────────────────────────
TELEGRAM_BOT_TOKEN=

# ── OPSIONAL: Debug ──────────────────────────────────────────
DEBUG=false

# ============================================================
# DASHBOARD SERVICE (set di service dashboard Railway)
# ============================================================
# NEXT_PUBLIC_BACKEND_URL=https://umkm-ai-suite-production.up.railway.app
