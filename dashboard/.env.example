# ============================================================
# Dashboard (Next.js) — Environment Variables
# ============================================================

# URL Suite Backend (FastAPI — AI, chat, konten, produk)
# Ini adalah backend utama yang melayani semua fitur dashboard.
# Masih di Railway — ganti dengan URL Railway service Anda.
BACKEND_URL=https://your-backend-suite.up.railway.app

# Versi client-side dari BACKEND_URL (dipakai langsung oleh browser via lib/api.ts)
# Harus sama dengan BACKEND_URL di atas.
NEXT_PUBLIC_BACKEND_URL=https://your-backend-suite.up.railway.app

# Catatan:
# - BACKEND_URL     dipakai server-side (Next.js API routes / proxy)
# - NEXT_PUBLIC_*   dipakai client-side (browser langsung)
# - Cloud backend (license/token) dikonfigurasi di backend suite (.env root), bukan di sini
