# ============================================================
# Dashboard (Next.js) — Environment Variables
# ============================================================

# URL backend FastAPI — digunakan server-side oleh proxy route
# Set ini di deployment Variables
BACKEND_URL=https://umkm-backend.aimarketingstrategic.com

# Client-side URL (dipakai langsung di browser oleh lib/api.ts)
NEXT_PUBLIC_BACKEND_URL=https://umkm-backend.aimarketingstrategic.com
