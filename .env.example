# ============================================================
# UMKM AI Suite — Konfigurasi Environment
# ============================================================

# === BACKEND LOKAL ===

# Database Lokal (SQLite — jangan diubah kecuali paham)
# Catatan: OPENAI_API_KEY tidak diperlukan di sini.
# Semua AI call diproxy melalui cloud backend — kunci hanya ada di cloud.
DATABASE_URL=sqlite+aiosqlite:///./umkm_local.db

# Cloud Server (dapatkan dari admin setelah beli lisensi)
# URL backend baru — ganti dengan URL Railway/VPS Anda
CLOUD_API_URL=https://umkm-backend.aimarketingstrategic.com
CLOUD_API_KEY=your-license-key-from-cloud

# n8n Webhook Security
N8N_WEBHOOK_SECRET=ganti-dengan-secret-acak-panjang

# CORS (kosongkan = izinkan semua origin, production isi dengan domain dashboard)
# CORS_ORIGINS=http://localhost:3000,https://dashboard.tokoku.com

# Profil Bisnis Default
BUSINESS_NAME=Toko Saya
BUSINESS_TYPE=retail

# === WEB CHAT WIDGET ===
# Untuk n8n workflow (webchat.json): ganti placeholder GANTI_DENGAN_* di JSON
# dengan credential ID yang sesuai di n8n instance Anda.
#
# Untuk embed di website client, copy kode dari webchat-widget/widget.html
# dan ganti BACKEND_URL dengan URL backend yang bisa diakses publik:
#   BACKEND_URL=https://your-backend.railway.app
#
# CORS: pastikan domain website client ada di daftar ini
# CORS_ORIGINS=https://websiteclient.com,https://www.websiteclient.com

# Notifikasi Telegram saat lead baru masuk via WebChat
# Dapatkan token dari @BotFather di Telegram
# TELEGRAM_BOT_TOKEN=123456:ABCDefgh...
# Chat ID diatur per-bisnis melalui PUT /api/webchat/config

# === CATATAN ===
# Cloud server (token, lisensi, billing) ada di repo terpisah:
# https://github.com/fxgatotsuryanto/umkm-ai-cloud
# Deploy ke Railway/VPS dan isi CLOUD_API_URL + CLOUD_API_KEY di atas.
#
# Alur koneksi AI Suite ↔ Cloud:
#   1. Login  : POST /api/auth/login  → cloud GET /license/validate
#   2. Balance: GET  /api/token/balance → cloud GET /token/balance (auto-sync tiap 5 menit)
#   3. Sync   : POST /api/token/sync-cloud → push transaksi lokal + pull saldo terbaru
#   4. Startup: saat server naik, transaksi offline otomatis dikirim ke cloud
