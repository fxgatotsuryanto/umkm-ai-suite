# ============================================================
# UMKM AI Suite — Konfigurasi Environment
# ============================================================

# === BACKEND LOKAL ===

# OpenRouter (https://openrouter.ai)
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini

# Database Lokal (SQLite — jangan diubah kecuali paham)
DATABASE_URL=sqlite+aiosqlite:///./umkm_local.db

# Cloud Server (dapatkan dari admin setelah beli lisensi)
CLOUD_API_URL=https://umkm-ai-cloud.up.railway.app
CLOUD_API_KEY=your-license-key-from-cloud

# n8n Webhook Security
N8N_WEBHOOK_SECRET=ganti-dengan-secret-acak-panjang

# CORS (kosongkan = izinkan semua origin, production isi dengan domain dashboard)
# CORS_ORIGINS=http://localhost:3000,https://dashboard.tokoku.com

# Profil Bisnis Default
BUSINESS_NAME=Toko Saya
BUSINESS_TYPE=retail

# === CATATAN ===
# Cloud server (token, lisensi, billing) ada di repo terpisah:
# https://github.com/fxgatotsuryanto/umkm-ai-cloud
# Deploy ke Railway dan dapatkan URL-nya, lalu isi CLOUD_API_URL di atas.
